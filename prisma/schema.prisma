generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
}

enum BookingStatus {
  PENDING_CONFIRMATION
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
  PENDING_PAYMENT
  EXPIRED
}

enum PaymentStatus {
  NOT_REQUIRED
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum BookingSource {
  WEBSITE
  ADMIN
}

model Profile {
  /// Matches auth.users.id. The relationship is enforced in the SQL migration because auth is outside Prisma's schema.
  id          String   @id @db.Uuid
  role        Role     @default(ADMIN)
  displayName String
  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)
}

model ServiceCategory {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  slug        String    @unique
  description String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)
  services    Service[]

  @@index([isActive, sortOrder])
}

model Service {
  id                    String          @id @default(uuid()) @db.Uuid
  categoryId            String          @db.Uuid
  name                  String
  slug                  String          @unique
  description           String
  basePriceUah          Int
  durationMinutes       Int
  bufferBeforeMinutes   Int             @default(0)
  bufferAfterMinutes    Int             @default(0)
  requiresConsultation  Boolean         @default(false)
  requiresDeposit       Boolean         @default(false)
  depositAmountUah      Int?
  isActive              Boolean         @default(true)
  sortOrder             Int             @default(0)
  createdAt             DateTime        @default(now()) @db.Timestamptz(3)
  updatedAt             DateTime        @updatedAt @db.Timestamptz(3)
  category              ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  bookings              Booking[]

  @@index([categoryId])
  @@index([isActive, sortOrder])
}

model Client {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  phone     String    @unique
  email     String?
  instagram String?
  telegram  String?
  notes     String?
  createdAt DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt DateTime  @updatedAt @db.Timestamptz(3)
  bookings  Booking[]

  @@index([phone])
}

model WorkingHours {
  id           String   @id @default(uuid()) @db.Uuid
  weekday      Int      @unique
  startTime    String   @db.VarChar(5)
  endTime      String   @db.VarChar(5)
  isWorkingDay Boolean  @default(true)
  createdAt    DateTime @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime @updatedAt @db.Timestamptz(3)
}

model ScheduleBlock {
  id        String   @id @default(uuid()) @db.Uuid
  startAt   DateTime @db.Timestamptz(3)
  endAt     DateTime @db.Timestamptz(3)
  reason    String?
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([startAt, endAt])
}

model Booking {
  id               String        @id @default(uuid()) @db.Uuid
  clientId         String        @db.Uuid
  serviceId        String        @db.Uuid
  startAt          DateTime      @db.Timestamptz(3)
  endAt            DateTime      @db.Timestamptz(3)
  /// Includes before-buffer time so overlap protection reserves the full operational interval.
  occupiedFrom     DateTime      @db.Timestamptz(3)
  /// Includes the service duration and after-buffer time. Availability always uses this value.
  occupiedUntil    DateTime      @db.Timestamptz(3)
  status           BookingStatus @default(PENDING_CONFIRMATION)
  totalPriceUah    Int
  depositAmountUah Int           @default(0)
  paymentStatus    PaymentStatus @default(NOT_REQUIRED)
  clientComment    String?
  adminNotes       String?
  source           BookingSource @default(WEBSITE)
  createdAt        DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime      @updatedAt @db.Timestamptz(3)
  cancelledAt      DateTime?     @db.Timestamptz(3)
  client           Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  service          Service       @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@index([startAt])
  @@index([status, startAt])
  @@index([clientId])
  @@index([serviceId])
}

// Future server-side extensions: Payment / MonobankInvoice, PortfolioItem,
// Product / Order / OrderItem, and ClientHairHistory.
